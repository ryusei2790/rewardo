# Docker イメージに含めないファイル・ディレクトリ
# node_modules はコンテナ内で npm ci により生成するため除外
node_modules
.next
out
build

# 環境変数ファイル（docker-compose の env_file で渡すため不要）
.env*
!.env.local.example

# Git 管理ファイル
.git
.gitignore

# OS・エディタ
.DS_Store
*.pem

# ログ
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ドキュメント（ビルドに不要）
docs/
README.md
